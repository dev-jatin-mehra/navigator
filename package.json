{
  "name": "navigator",
  "displayName": "navigator",
  "description": "Simple yet useful route navigation for React Applications",
  "version": "0.0.1",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-jatin-mehra/navigator.git"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "activationEvents": [
    "onCommand:navigator.openRouteExposer"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "navigator.openRouteExposer",
        "title": "Navigator: Open Route Exposer",
        "category": "Navigator"
      }
    ],
    "configuration": {
      "title": "Navigator",
      "properties": {
        "navigator.routeFileGlobs": {
          "type": "array",
          "default": [
            "**/*.{ts,tsx,js,jsx}"
          ],
          "description": "Glob patterns the route exposer scans for React Router definitions."
        },
        "navigator.defaultPort": {
          "type": "number",
          "default": 5173,
          "minimum": 1,
          "maximum": 65535,
          "description": "Default localhost port used when opening a route."
        },
        "navigator.startCommand": {
          "type": "string",
          "default": "npm run dev",
          "description": "Command used to start the React app when Navigator does not detect a running app."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}